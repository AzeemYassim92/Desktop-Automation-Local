<Window x:Class="DesktopAutomationLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Desktop Automation Lab"
        Width="1100"
        Height="760"
        MinWidth="950"
        MinHeight="680"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#111827">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Margin="16,16,16,8"
                Padding="18"
                CornerRadius="14"
                Background="#1F2937">
            <StackPanel>
                <TextBlock Text="Desktop Automation Lab"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="White" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#D1D5DB"
                           Text="A safe desktop automation playground for hotkeys, screen regions, cursor tracking, and color sampling." />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="16,0,16,8"
                    Background="#111827"
                    BorderBrush="#374151"
                    Foreground="White">
            <TabItem Header="Hotkeys">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,0,12,0" Padding="16" Background="#1F2937" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="Global Toggle Hotkey" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Margin="0,6,0,14" Foreground="#D1D5DB"
                                       Text="Register one system-wide hotkey to start or stop your lab workflow." />

                            <CheckBox Margin="0,0,0,8" Content="Ctrl" IsChecked="{Binding Settings.Hotkey.Ctrl}" />
                            <CheckBox Margin="0,0,0,8" Content="Alt" IsChecked="{Binding Settings.Hotkey.Alt}" />
                            <CheckBox Margin="0,0,0,8" Content="Shift" IsChecked="{Binding Settings.Hotkey.Shift}" />
                            <CheckBox Margin="0,0,0,14" Content="Windows Key" IsChecked="{Binding Settings.Hotkey.Win}" />

                            <TextBlock Text="Virtual Key (examples: F6, F8, A, Z)" Foreground="#D1D5DB" />
                            <TextBox Margin="0,6,0,14"
                                     Padding="8"
                                     Text="{Binding Settings.Hotkey.KeyText, UpdateSourceTrigger=PropertyChanged}" />

                            <WrapPanel>
                                <Button Padding="12,8"
                                        Margin="0,0,8,0"
                                        Content="Register Hotkey"
                                        Command="{Binding RegisterHotkeyCommand}" />
                                <Button Padding="12,8"
                                        Content="Unregister Hotkey"
                                        Command="{Binding UnregisterHotkeyCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="16" Background="#1F2937" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="Status" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Margin="0,10,0,8" Foreground="#D1D5DB" Text="{Binding HotkeyStatus}" />
                            <TextBlock Margin="0,10,0,6" Text="Notes" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock TextWrapping="Wrap" Foreground="#D1D5DB"
                                       Text="This lab registers a single global hotkey with Windows. It is intended for learning, UI testing, and desktop utility workflows you control." />
                            <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#D1D5DB"
                                       Text="When the hotkey fires, the app toggles an internal Running state and writes to the log panel." />
                            <TextBlock Margin="0,18,0,4" Text="Running State" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Foreground="#A7F3D0" FontSize="20" FontWeight="Bold" Text="{Binding RunningStateText}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Inspector">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,0,12,0" Padding="16" Background="#1F2937" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="Cursor and Region Inspector" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Margin="0,6,0,14" Foreground="#D1D5DB"
                                       Text="Capture the cursor, define a rectangular region, and sample screen colors." />

                            <WrapPanel Margin="0,0,0,14">
                                <Button Padding="12,8" Margin="0,0,8,8" Content="Capture Cursor" Command="{Binding CaptureCursorCommand}" />
                                <Button Padding="12,8" Margin="0,0,8,8" Content="Set Region Start" Command="{Binding SetRegionStartCommand}" />
                                <Button Padding="12,8" Margin="0,0,8,8" Content="Set Region End" Command="{Binding SetRegionEndCommand}" />
                            </WrapPanel>

                            <WrapPanel Margin="0,0,0,14">
                                <Button Padding="12,8" Margin="0,0,8,8" Content="Start Sampling" Command="{Binding StartSamplingCommand}" />
                                <Button Padding="12,8" Margin="0,0,8,8" Content="Stop Sampling" Command="{Binding StopSamplingCommand}" />
                                <Button Padding="12,8" Margin="0,0,8,8" Content="Center Region On Cursor" Command="{Binding CenterRegionOnCursorCommand}" />
                                <Button Padding="12,8" Margin="0,0,8,8" Content="Take Screenshot" Command="{Binding TakeScreenshotCommand}" />
                            </WrapPanel>

                            <TextBlock Text="Sample Interval (ms)" Foreground="#D1D5DB" />
                            <TextBox Margin="0,6,0,14" Padding="8" Text="{Binding Settings.SampleIntervalMs, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="Region Width" Foreground="#D1D5DB" />
                            <TextBox Margin="0,6,0,10" Padding="8" Text="{Binding Settings.Region.Width, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="Region Height" Foreground="#D1D5DB" />
                            <TextBox Margin="0,6,0,0" Padding="8" Text="{Binding Settings.Region.Height, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="16" Background="#1F2937" CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Live Values" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                                <TextBlock Margin="0,10,0,4" Foreground="#D1D5DB" Text="{Binding CursorText}" />
                                <TextBlock Margin="0,0,0,4" Foreground="#D1D5DB" Text="{Binding RegionText}" />
                                <TextBlock Margin="0,0,0,10" Foreground="#D1D5DB" Text="{Binding SamplerStatus}" />
                            </StackPanel>

                            <Border Grid.Row="1" Margin="0,0,0,14" Width="200" Height="120" CornerRadius="10" Background="{Binding CurrentSampleBrush}">
                                <Grid>
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               Text="{Binding CurrentSampleHex}" />
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,30,0">
                                    <TextBlock Text="R" Foreground="#D1D5DB" />
                                    <TextBlock FontSize="18" Foreground="White" Text="{Binding CurrentSample.Red}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="G / B" Foreground="#D1D5DB" />
                                    <TextBlock FontSize="18" Foreground="White" Text="{Binding CurrentSample.GreenBlueText}" />
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="3" Padding="12" Background="#111827" CornerRadius="10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding RecentSamples}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8" Padding="10" Background="#1F2937" CornerRadius="8">
                                                    <TextBlock Foreground="#D1D5DB" Text="{Binding}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,0,12,0" Padding="16" Background="#1F2937" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="Persistence" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Margin="0,6,0,14" Foreground="#D1D5DB"
                                       Text="Save and load app settings as JSON in your local AppData folder." />

                            <WrapPanel>
                                <Button Padding="12,8" Margin="0,0,8,0" Content="Save Settings" Command="{Binding SaveSettingsCommand}" />
                                <Button Padding="12,8" Content="Load Settings" Command="{Binding LoadSettingsCommand}" />
                            </WrapPanel>

                            <TextBlock Margin="0,18,0,4" Text="Settings File" Foreground="#D1D5DB" />
                            <TextBox Padding="8" Text="{Binding SettingsFilePath, Mode=OneWay}" IsReadOnly="True" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="16" Background="#1F2937" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="Current Settings Snapshot" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Margin="0,10,0,0" Foreground="#D1D5DB" Text="{Binding SettingsSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Logs">
                <Border Margin="12" Padding="12" Background="#1F2937" CornerRadius="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding LogEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="10" Background="#111827" CornerRadius="8">
                                        <TextBlock Foreground="#E5E7EB" Text="{Binding}" TextWrapping="Wrap" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Margin="16,0,16,16"
                Padding="12"
                CornerRadius="10"
                Background="#1F2937">
            <TextBlock Foreground="#D1D5DB"
                       Text="Built for learning: global hotkeys, region capture, screen color sampling, JSON settings, and structured logs." />
        </Border>
    </Grid>
</Window>
